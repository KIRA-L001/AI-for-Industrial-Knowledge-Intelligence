# ─────────────────────────────────────────────────────────────
# KIRA — Environment configuration (copy to .env and adjust)
# ─────────────────────────────────────────────────────────────

# --- General ---
KIRA_ENV=development
LOG_LEVEL=INFO

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Security / Auth ---
# CHANGE THIS in any non-local environment (openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kira
POSTGRES_PASSWORD=kira_password
POSTGRES_DB=kira
# Async SQLAlchemy URL (overrides component vars if set)
DATABASE_URL=postgresql+asyncpg://kira:kira_password@postgres:5432/kira

# --- Redis (cache + Celery broker/result) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Neo4j (knowledge graph) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kira_neo4j_password

# --- Qdrant (vector DB) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kira_chunks

# --- MinIO (object storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=kira
MINIO_SECRET_KEY=kira_minio_password
MINIO_BUCKET=kira-documents
MINIO_SECURE=false

# --- AI / LLM (provider-agnostic layer) ---
# Provider: one of [anthropic, openai, ollama, none]
LLM_PROVIDER=none
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
# Embeddings (Sentence Transformers checkpoint)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
